generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String              @id @default(cuid())
  name             String?
  email            String              @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  role             UserRole            @default(USER)
  institution      String?
  researchArea     String?
  bio              String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  accounts         Account[]
  chatSessions     ChatSession[]
  creditBalance    CreditBalance?
  creditTxns       CreditTransaction[]
  pipelineProjects PipelineProject[]
  protocols        Protocol[]
  sessions         Session[]
  subscription     Subscription?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String             @unique
  plan               SubscriptionPlan   @default(FREE)
  status             SubscriptionStatus @default(TRIALING)
  currentPeriodStart DateTime           @default(now())
  currentPeriodEnd   DateTime           @default(dbgenerated("(now() + '7 days'::interval)"))
  trialEndsAt        DateTime?
  cancelledAt        DateTime?
  monthlyCredits     Int                @default(50)
  externalId         String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model CreditBalance {
  id          String   @id @default(cuid())
  userId      String   @unique
  balance     Int      @default(50)
  totalEarned Int      @default(50)
  totalSpent  Int      @default(0)
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_balances")
}

model CreditTransaction {
  id          String          @id @default(cuid())
  userId      String
  type        TransactionType
  amount      Int
  balance     Int
  description String
  metadata    Json?
  createdAt   DateTime        @default(now())
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("credit_transactions")
}

model PipelineProject {
  id                String          @id @default(cuid())
  userId            String
  name              String
  description       String?
  tissueType        String
  status            PipelineStatus  @default(DRAFT)
  currentStage      Int             @default(1)
  targetApplication String?
  patientProfile    String?
  completionRate    Float           @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  stages            PipelineStage[]

  @@index([userId])
  @@index([status])
  @@map("pipeline_projects")
}

model PipelineStage {
  id          String          @id @default(cuid())
  projectId   String
  stageNumber Int
  name        String
  description String
  status      StageStatus     @default(PENDING)
  inputs      Json?
  outputs     Json?
  aiAnalysis  String?
  creditsUsed Int?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  project     PipelineProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, stageNumber])
  @@index([projectId])
  @@map("pipeline_stages")
}

model Biomaterial {
  id               String              @id @default(cuid())
  name             String
  category         BiomaterialCategory
  components       String[]
  composition      Json
  elasticity       Float?
  porosity         Float?
  degradationTime  String?
  biocompatibility String
  printable        Boolean             @default(false)
  crosslinking     String?
  applications     String[]
  tissueTypes      String[]
  references       String[]
  doi              String[]
  tags             String[]
  isPublic         Boolean             @default(true)
  verified         Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  formulations     FormulationRecord[]

  @@index([category])
  @@map("biomaterials")
}

model FormulationRecord {
  id            String      @id @default(cuid())
  userId        String?
  biomaterialId String
  customInputs  Json?
  aiSuggestion  String?
  notes         String?
  creditsUsed   Int         @default(10)
  createdAt     DateTime    @default(now())
  biomaterial   Biomaterial @relation(fields: [biomaterialId], references: [id], onDelete: NoAction)

  @@index([biomaterialId])
  @@map("formulation_records")
}

model OrganoidDesign {
  id           String       @id @default(cuid())
  userId       String
  name         String
  organoidType OrganoidType
  cellTypes    String[]
  scaffold     String?
  dimensions   Json?
  protocol     String?
  aiDesign     String?
  predictions  Json?
  creditsUsed  Int          @default(15)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([userId])
  @@map("organoid_designs")
}

model Protocol {
  id           String   @id @default(cuid())
  userId       String
  title        String
  category     String
  description  String?
  steps        Json
  materials    Json
  equipment    String[]
  safetyNotes  String[]
  aiGenerated  Boolean  @default(true)
  sourceInputs Json?
  duration     String?
  difficulty   String?
  validated    Boolean  @default(false)
  creditsUsed  Int      @default(8)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@map("protocols")
}

model KnowledgeArticle {
  id          String   @id @default(cuid())
  title       String
  authors     String[]
  abstract    String
  journal     String
  year        Int
  doi         String?  @unique
  url         String?
  tags        String[]
  category    String
  keywords    String[]
  embedding   Float[]
  chunkCount  Int      @default(0)
  isPublic    Boolean  @default(true)
  accessCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([year])
  @@map("knowledge_articles")
}

model ChatSession {
  id           String        @id @default(cuid())
  userId       String
  title        String        @default("Nova Conversa")
  isActive     Boolean       @default(true)
  context      String?
  messageCount Int           @default(0)
  totalCredits Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     ChatMessage[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("chat_sessions")
}

model ChatMessage {
  id          String      @id @default(cuid())
  sessionId   String
  role        String
  content     String
  model       String?
  tokens      Int?
  creditsUsed Int         @default(0)
  sources     Json?
  createdAt   DateTime    @default(now())
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("chat_messages")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

enum UserRole {
  USER
  ADMIN
  RESEARCHER
}

enum SubscriptionPlan {
  FREE
  DISCOVERY
  ADVANCED
  ENTERPRISE
  ACADEMY
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum PipelineStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum StageStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum BiomaterialCategory {
  HYDROGEL
  SCAFFOLD
  BIOINK
  MEMBRANE
  COATING
  COMPOSITE
  DECELLULARIZED
  NANOPARTICLE
}

enum OrganoidType {
  BRAIN
  HEART
  LIVER
  KIDNEY
  INTESTINE
  LUNG
  PANCREAS
  RETINA
  CUSTOM
}
